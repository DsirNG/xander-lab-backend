# Xander Lab Backend - 生产环境配置模板
# 使用说明: 复制此文件为 .env.production 并填入真实值
# 注意: .env.production 已被 git 忽略，请勿上传敏感信息

# 1. 镜像仓库配置 (用于部署脚本)
ALIYUN_REGISTRY_URL=registry.cn-hangzhou.aliyuncs.com
ALIYUN_REGISTRY_NAMESPACE=your-namespace
ALIYUN_REGISTRY_USERNAME=your-username
ALIYUN_REGISTRY_PASSWORD=your-password

# 2. 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://your-server-ip:3306/xander_lab?useUnicode=true&characterEncoding=utf-8&useSSL=false&connectionTimeZone=Asia%2FShanghai&forceConnectionTimeZoneToSession=true&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# 3. 邮件配置
RESEND_API_KEY=re_your_resend_sending_key
MAIL_FROM=noreply@mail.dsircity.top
EMAIL_REMINDER_ENABLED=true
EMAIL_REMINDER_POLL_INTERVAL_MS=1000
EMAIL_REMINDER_MAX_SEND_ATTEMPTS=3
EMAIL_REMINDER_RETRY_DELAY_MS=30000

# 4. 阿里云 OSS 配置
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret

# 5. JWT 配置
JWT_SECRET=your_jwt_secret_at_least_32_chars

# 6. 博客智能体（图片模型留空时只生成文章，不生成插图）
BLOG_AGENT_BASE_URL=https://api.openai.com/v1
BLOG_AGENT_API_KEY=your_agent_api_key
BLOG_AGENT_MODEL=your_text_model
BLOG_AGENT_WEB_SEARCH_ENABLED=true
BLOG_AGENT_IMAGE_MODEL=
BLOG_AGENT_IMAGE_SIZE=1536x1024
BLOG_AGENT_MAX_ILLUSTRATIONS=3
